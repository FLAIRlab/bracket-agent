# Copy this file to .env and fill in your keys.
# Only one key is required — the agent auto-detects which backend to use.

# Anthropic  (claude-sonnet-4-6)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI  (gpt-5.2)
OPENAI_API_KEY=sk-...

# Optional overrides
# AGENT_BACKEND=anthropic   # force a backend when both keys are present
# OPENAI_MODEL=gpt-5.2      # override the OpenAI model
